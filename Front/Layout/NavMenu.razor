<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">Front</a>
        <button title="Navigation menu" class="navbar-toggler" @onclick="ToggleNavMenu">
            <span class="navbar-toggler-icon"></span>
        </button>
    </div>
</div>

<div class="@NavMenuCssClass nav-scrollable" @onclick="ToggleNavMenu">
    <nav class="nav flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> Home
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="subir-archivo">
                <span class="bi bi-plus-square-fill-nav-menu" aria-hidden="true"></span> Subir Archivo
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="Archivos">
                <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> Archivos
            </NavLink>
        </div>

        <!--Menú expandible de Categorías-->
        <div class="nav-item px-3">
            <div class="nav-link" @onclick="() => expandSubNav = !expandSubNav" style="cursor: pointer;">
                <span class="bi bi-folder-fill" aria-hidden="true"></span> Categorías
                <span class="@(expandSubNav ? "bi bi-chevron-down" : "bi bi-chevron-right") float-end"></span>
            </div>
            @if (expandSubNav)
            {
                <nav class="flex-column ps-3">
                    <div class="nav-item">
                        <NavLink class="nav-link sub-item" href="categorias">
                            <span class="bi bi-gear-fill"></span> Gestionar Categorías
                        </NavLink>
                    </div>
                    <div class="nav-item">
                        <NavLink class="nav-link sub-item" href="archivos">
                            <span class="bi bi-grid-fill"></span> Ver Archivos
                        </NavLink>
                    </div>
                </nav>
            }
        </div>

    </nav>
</div>

@code {

    private bool expandSubNav;

    private bool collapseNavMenu = true;

    private string? NavMenuCssClass => collapseNavMenu ? "collapse" : null;

    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }
}
