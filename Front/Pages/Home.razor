@page "/"
@inject Front.Servicios.IArchivoService ArchivoService
@inject Front.Servicios.ICategoriaService CategoriaService
@inject IJSRuntime JSRuntime
@inject NavigationManager Navigation

<PageTitle>NubeCasera - Mis Archivos</PageTitle>

<div class="container py-4">
    <h1>📁 Mis Archivos</h1>

    @if (cargando)
    {
        <div class="spinner-border" role="status">
            <span class="visually-hidden">Cargando...</span>
        </div>
        <p>Cargando archivos...</p>
    }
    else if (error != null)
    {
        <div class="alert alert-danger">
            <strong>Error:</strong> @error
        </div>
    }
    else
    {
        <div class="alert alert-success">
            ✅ Servicios cargados correctamente
        </div>
        <p>Total de archivos: @archivos.Count</p>
        @* <p>Total de categorías: @categorias.Count</p> *@
    }
</div>

@code {
    private List<ArchivoReferenciaDTO> archivos = new();
    // private List<CategoriaDTO> categorias = new();
    private bool cargando = true;
    private string? error;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            cargando = true;
            error = null;

            // Intentar cargar datos
            // categorias = await CategoriaService.ObtenerCategoriasAsync();
            archivos = await ArchivoService.ObtenerArchivosAsync();
        }
        catch (HttpRequestException ex)
        {
            error = $"Error de conexión: {ex.Message}. ¿Está el backend corriendo en http://localhost:5158?";
        }
        catch (Exception ex)
        {
            error = $"Error: {ex.Message}";
        }
        finally
        {
            cargando = false;
        }
    }
}